# syntax=docker/dockerfile:1

# =============================================================================
# Base Stage - Shared Dependencies
# =============================================================================
FROM python:3.11-slim AS base

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        gcc \
        g++ \
        curl && \
    rm -rf /var/lib/apt/lists/*

# =============================================================================
# Stage 1: Data Fetcher
# =============================================================================
FROM base AS data-fetcher

COPY build/requirements.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    echo "📦 Installing packages for data-fetcher..." && \
    pip install --progress-bar on -r requirements.txt && \
    echo "✅ Packages installed successfully!"

COPY scripts/fetch_data.py ./scripts/

ENV OUTPUT_DIR=/data
ENV LOG_LEVEL=INFO

ENTRYPOINT ["python", "scripts/fetch_data.py"]


# =============================================================================
# Stage 2: Model Trainer
# =============================================================================
FROM base AS trainer

COPY build/requirements.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    echo "🤖 Installing packages for trainer..." && \
    pip install --progress-bar on -r requirements.txt && \
    echo "✅ Packages installed successfully!"

COPY scripts/train_model.py ./scripts/

ENV DATA_DIR=/data/latest
ENV MODEL_DIR=/models
ENV EPOCHS=50
ENV BATCH_SIZE=32
ENV NUM_HEROES=130
ENV LOG_LEVEL=INFO

ENTRYPOINT ["python", "scripts/train_model.py"]


# =============================================================================
# Stage 3: API Server (Production)
# =============================================================================
FROM base AS api

COPY build/requirements.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    echo "🌐 Installing packages for API..." && \
    pip install --progress-bar on -r requirements.txt && \
    echo "✅ Packages installed successfully!"

COPY src/api ./src/api

ENV MODEL_DIR=/models
ENV LOG_LEVEL=INFO
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD python -c "import requests; requests.get('http://localhost:8000/health')"

CMD ["gunicorn", "--bind", "0.0.0.0:8000", "--workers", "4", "--timeout", "120", "src.api.app:app"]


# =============================================================================
# Stage 4: ML Pipeline
# =============================================================================
FROM base AS ml-pipeline

COPY build/requirements.txt .

RUN --mount=type=cache,target=/root/.cache/pip \
    echo "🔬 Installing packages for ML pipeline..." && \
    pip install --progress-bar on -r requirements.txt && \
    echo "✅ Packages installed successfully!"

COPY scripts/ ./scripts/

ENV DATA_DIR=/data/ml-training
ENV MODEL_DIR=/models
ENV EPOCHS=50
ENV BATCH_SIZE=32
ENV LOG_LEVEL=INFO
ENV PYTHONPATH=/app

CMD ["python", "scripts/train_model.py"]